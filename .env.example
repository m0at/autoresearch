# Copy to .env and fill in your values.
# Used by manage_instances.sh and any local orchestration scripts.

# vast.ai API key — get from https://cloud.vast.ai/account/
VAST_API_KEY=your_key_here

# SSH connection strings for your H100 instances (update after each new instance)
INST1_HOST=ssh3.vast.ai
INST1_PORT=26218

INST2_HOST=ssh2.vast.ai
INST2_PORT=37220

INST3_HOST=ssh7.vast.ai
INST3_PORT=17364

INST4_HOST=ssh4.vast.ai
INST4_PORT=17364

# Local paths
RESULTS_DIR=./results
BINARY_CACHE=/tmp/autoresearch-engine-latest
